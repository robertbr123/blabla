# Aplicação
ENV=development
LOG_LEVEL=INFO

# Banco de dados
DATABASE_URL=postgresql+asyncpg://ondeline:ondeline@postgres:5432/ondeline
DATABASE_URL_SYNC=postgresql+psycopg://ondeline:ondeline@postgres:5432/ondeline

# Redis
REDIS_URL=redis://redis:6379/0

# Evolution API (WhatsApp) — preenchido em M3
EVOLUTION_URL=http://localhost:8080
EVOLUTION_KEY=
EVOLUTION_HMAC_SECRET=
EVOLUTION_INSTANCE=hermes-wa
EVOLUTION_IP_ALLOWLIST=

# Webhook
WEBHOOK_MAX_BODY_BYTES=1048576
WEBHOOK_RATE_LIMIT=100/minute

# Bot
BOT_ACK_TEXT=Olá! 😊 Recebi sua mensagem. Em instantes um de nossos atendentes vai falar com você.

# Celery (vazio = usa REDIS_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# SGP (Sistema de Gestão de Provedor) — preenchido em M4
SGP_ONDELINE_BASE=https://ondeline.sgp.tsmx.com.br
SGP_ONDELINE_TOKEN=
SGP_ONDELINE_APP=mikrotik
SGP_LINKNETAM_BASE=https://linknetam.sgp.net.br
SGP_LINKNETAM_TOKEN=
SGP_LINKNETAM_APP=APP

# Hermes LLM — preenchido em M4
HERMES_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=Hermes-3

# LLM controls
LLM_MAX_ITER=5
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS_PER_CONVERSA_DIA=50000
LLM_HISTORY_TURNS=12

# SGP cache TTLs (segundos)
SGP_CACHE_TTL_CLIENTE=3600
SGP_CACHE_TTL_FATURAS=300
SGP_CACHE_TTL_NEGATIVO=300

# Auth — preenchido em M2
JWT_SECRET=
PII_ENCRYPTION_KEY=
PII_HASH_PEPPER=

# Optional pre-computed argon2id hash used to keep /auth/login response time
# constant when the email doesn't exist. Leave empty to let the API compute one
# lazily at first miss.
DUMMY_PASSWORD_HASH=

# Observabilidade — opcional
SENTRY_DSN=

# OpenTelemetry (M8) — opcional. Endpoint HTTP do OTLP receiver (ex: Tempo, Otel collector).
# Vazio = traces desligados. Format: http://host:4318 (sem /v1/traces — o cliente adiciona).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ondeline-api

# Initial admin user — populated before running scripts/seed-admin.sh
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

