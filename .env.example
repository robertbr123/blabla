# Aplicação
ENV=development
LOG_LEVEL=INFO

# Banco de dados
DATABASE_URL=postgresql+asyncpg://ondeline:ondeline@postgres:5432/ondeline
DATABASE_URL_SYNC=postgresql+psycopg://ondeline:ondeline@postgres:5432/ondeline

# Redis
REDIS_URL=redis://redis:6379/0

# Evolution API (WhatsApp) — preenchido em milestones futuros
EVOLUTION_URL=http://localhost:8080
EVOLUTION_KEY=
EVOLUTION_HMAC_SECRET=

# SGP (Sistema de Gestão de Provedor) — preenchido em M4
SGP_ONDELINE_BASE=https://ondeline.sgp.tsmx.com.br
SGP_ONDELINE_TOKEN=
SGP_ONDELINE_APP=mikrotik
SGP_LINKNETAM_BASE=https://linknetam.sgp.net.br
SGP_LINKNETAM_TOKEN=
SGP_LINKNETAM_APP=APP

# Hermes LLM — preenchido em M4
HERMES_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=anthropic/claude-opus-4.6

# Auth — preenchido em M2
JWT_SECRET=
PII_ENCRYPTION_KEY=
PII_HASH_PEPPER=

# Observabilidade — opcional
SENTRY_DSN=
