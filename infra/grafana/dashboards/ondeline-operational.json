{
  "title": "Ondeline — Operational",
  "uid": "ondeline-operational",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["ondeline", "m8", "operational"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Webhooks recebidos (rate, 5min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_webhook_received_total[5m])",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Webhooks HMAC inválido (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_webhook_invalid_signature_total[5m])",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Webhooks rate-limited (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_webhook_rate_limited_total[5m])",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mensagens processadas/min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_msgs_processed_total[1m]) * 60",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Dedup ratio (5min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_msgs_dedup_total[5m]) / clamp_min(rate(ondeline_msgs_processed_total[5m]), 0.0001)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Evolution success rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ondeline_evolution_send_total[5m]) / clamp_min((rate(ondeline_evolution_send_total[5m]) + rate(ondeline_evolution_send_failure_total[5m])), 0.0001)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Process resident memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Process CPU (rate, 1min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total[1m])",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
