# =============================================================
# blabla / Ondeline v2 — Configuração de produção
# =============================================================
# Copie para `.env` e preencha. Variáveis sem valor default são
# obrigatórias em produção.

# ─── Aplicação ────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ─── Banco de dados ───────────────────────────────────────────
POSTGRES_USER=blabla
POSTGRES_PASSWORD=
POSTGRES_DB=blabla
DATABASE_URL=postgresql+asyncpg://blabla:blabla@postgres:5432/blabla
DATABASE_URL_SYNC=postgresql+psycopg://blabla:blabla@postgres:5432/blabla

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Evolution API (WhatsApp) ─────────────────────────────────
# Modo 1 — Evolution rodando localmente (docker compose --profile evolution up -d):
#   EVOLUTION_URL=http://evolution-api:8080
# Modo 2 — Evolution em máquina externa:
#   EVOLUTION_URL=http://IP_OU_DOMINIO:8080
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_KEY=
EVOLUTION_HMAC_SECRET=
# F4: este é o nome da instância PRINCIPAL (canal default "suporte"). Para
# canais adicionais (ex: comercial), crie instances extras na Evolution
# e registre via POST /api/v1/canais.
EVOLUTION_INSTANCE=hermes-wa
EVOLUTION_IP_ALLOWLIST=

# URL pública do Evolution (callbacks/webhooks da própria Evolution)
EVOLUTION_SERVER_URL=

# ─── WhatsApp Cloud API (Meta) ────────────────────────────────
# Configure apenas se for usar um canal com provider='cloud'.
# Deixa tudo vazio se só vai usar Evolution — canais Cloud falham com 503
# até serem preenchidos.
#
# Setup no Meta:
#   1. business.facebook.com → WhatsApp Manager → seu app
#   2. Configuration → Webhooks:
#        Callback URL: https://SEU-DOMINIO/webhook/whatsapp-cloud
#        Verify token: o mesmo valor de WHATSAPP_CLOUD_VERIFY_TOKEN abaixo
#        Subscribe to: messages
#   3. Settings → Basic → App Secret → WHATSAPP_CLOUD_APP_SECRET
#   4. System Users → gerar token permanente → WHATSAPP_CLOUD_ACCESS_TOKEN
#
# Token aleatório pra verify: openssl rand -hex 32
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_GRAPH_VERSION=v21.0

# ─── Webhook ──────────────────────────────────────────────────
WEBHOOK_MAX_BODY_BYTES=1048576
WEBHOOK_RATE_LIMIT=100/minute

# ─── CORS ─────────────────────────────────────────────────────
# DEVE listar TODOS os hosts onde Dashboard e PWA do técnico rodam,
# separados por VÍRGULA, sem espaço, com protocolo (https://) e sem barra final.
# Esquecer um host = navegador bloqueia login com "Failed to fetch".
# Ex: CORS_ORIGINS=https://blabla.seudominio.com,https://tec.seudominio.com
CORS_ORIGINS=

# ─── Auth (M2) ────────────────────────────────────────────────
# Geração: openssl rand -hex 32
JWT_SECRET=
# Geração: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=
# Geração: openssl rand -hex 32
PII_HASH_PEPPER=
# Hash argon2id pré-computado pra evitar timing oracle em /auth/login com
# email inexistente. Vazio = API computa lazy.
DUMMY_PASSWORD_HASH=

# ─── SGP (Sistema de Gestão de Provedor) ──────────────────────
# Tokens podem ser sobrescritos via dashboard /config (DB > env).
SGP_ONDELINE_BASE=https://ondeline.sgp.tsmx.com.br
SGP_ONDELINE_TOKEN=
SGP_ONDELINE_APP=mikrotik
SGP_LINKNETAM_BASE=https://linknetam.sgp.net.br
SGP_LINKNETAM_TOKEN=
SGP_LINKNETAM_APP=APP
SGP_CACHE_TTL_CLIENTE=3600
SGP_CACHE_TTL_FATURAS=300
SGP_CACHE_TTL_NEGATIVO=300

# ─── LLM ──────────────────────────────────────────────────────
# Provider: 'openai' (padrão) | 'hermes' (self-hosted) | 'xai'
LLM_PROVIDER=openai

# OpenAI (recomendado em produção; também usado por F7 transcrição de áudio).
OPENAI_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hermes (legacy / on-prem). Usado quando LLM_PROVIDER=hermes.
HERMES_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=Hermes-3

# Controles LLM
LLM_MAX_ITER=5
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS_PER_CONVERSA_DIA=50000
LLM_HISTORY_TURNS=12

# ─── F7 — Bot por voz (OpenAI Whisper API) ────────────────────
# Reutiliza OPENAI_API_KEY (acima). Sem chave → áudios voltam ao
# comportamento antigo (só ACK, sem transcrição).
OPENAI_ASR_MODEL=whisper-1
OPENAI_ASR_LANGUAGE=pt
# Áudios maiores que isso são pulados (cliente é avisado a mandar texto).
OPENAI_ASR_MAX_SECONDS=120
# Limite da API OpenAI: 25 MB.
OPENAI_ASR_MAX_BYTES=26214400
OPENAI_ASR_TIMEOUT_SECONDS=30

# ─── Bot — texto padrão ───────────────────────────────────────
BOT_ACK_TEXT=Olá! 😊 Recebi sua mensagem. Em instantes um de nossos atendentes vai falar com você.

# ─── Celery ───────────────────────────────────────────────────
# Vazio = usa REDIS_URL.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ─── Observabilidade (opcional) ───────────────────────────────
SENTRY_DSN=
# OpenTelemetry: http://host:4318 (sem /v1/traces — o cliente adiciona).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ondeline-api

# ─── Admin inicial (para scripts/seed-admin.sh) ───────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# ─── Deploy (GHCR) ────────────────────────────────────────────
GHCR_OWNER=

# =============================================================
# Roteiro de configuração das features v3 (Fase A-D)
# =============================================================
# A maioria das features novas (F0-F7) NÃO exige env var nova. Abaixo,
# o que precisa ser feito FORA do .env (dashboard, painel SGP, API admin).
#
# ── F0 — Nome do cliente em conversas ────────────────────────
#   Nada a configurar. Funciona automaticamente quando bot identifica cliente.
#
# ── F1 — Resumo automático bot→humano ────────────────────────
#   Nada a configurar. Usa o LLM já configurado (OPENAI_API_KEY).
#
# ── F2 — Régua de cobrança automática ────────────────────────
#   Beat dispara 09:00 BRT (timezone do Celery = America/Sao_Paulo).
#   Gatilhos: D-3, D+1, D+5, D+15.
#   Cliente pode desativar respondendo "PARAR" no WhatsApp; reativa com "VOLTAR".
#   Não há env var — para mudar horário/gatilhos, editar código (futuro: dashboard).
#
# ── F3 — Pix QR Code ─────────────────────────────────────────
#   Configurar no PAINEL DO SGP que cada fatura traga o campo `codigoPix`.
#   Sem isso, lembrete vai só com PDF (sem QR). Monitorar métrica:
#     ondeline_pix_qr_source_total{fonte="indisponivel"}
#
# ── F4 — Multi-instância WhatsApp ────────────────────────────
#   Canal default ("suporte") criado automaticamente no startup, apontando
#   pra EVOLUTION_INSTANCE. Para adicionar canais (ex: "comercial"):
#     1. Criar 2a instância na Evolution (ex: nome "comercial-wa")
#     2. Apontar o webhook dessa instância pra mesma URL /webhook
#     3. POST /api/v1/canais (admin):
#        {"slug":"comercial","nome":"Comercial","evolution_instance":"comercial-wa"}
#
# ── F5 — A/B test de prompts ─────────────────────────────────
#   Criar variantes via API admin:
#     POST /api/v1/prompts
#     {"nome":"v2","system_prompt":"...","trafego_pct":20,"ativo":true}
#   Verificar distribuição:
#     GET /api/v1/prompts/stats
#
# ── F6 — Estoque do técnico ──────────────────────────────────
#   Cadastrar itens via API admin:
#     POST /api/v1/estoque/itens
#     {"sku":"ONU-XPON-ZTE","nome":"ONU XPON ZTE","categoria":"onu","serializado":true}
#   Dar entrada inicial pra cada técnico:
#     POST /api/v1/estoque/movimentos
#     {"item_id":"...","tipo":"entrada","quantidade":10,"tecnico_id":"..."}
#   Saldo do técnico aparece em /estoque no dashboard e em /estoque no PWA.
#
# ── F8 — Histórico de equipamentos por cliente ───────────────
#   Automático. Sempre que técnico fizer `saida` com serial + ordem_servico_id,
#   sistema cria registro em cliente_equipamento via hook no service de estoque.
#   Quando recolhido (mesmo serial), fecha o registro. Ver em /clientes/[id].
#
# ── F9 — Comissão / produtividade ─────────────────────────────
#   Config no /api/v1/config (admin):
#     POST {"key":"comissao.valor_por_os","value":30}
#     POST {"key":"comissao.bonus_csat_5","value":5}
#     POST {"key":"comissao.bonus_csat_4","value":2}
#   Sem config = R$ 0. Relatório em /tecnicos/produtividade.
#
# ── F10 — Indicação "Indicou, ganhou" ─────────────────────────
#   Cliente identificado manda "INDICAR" no WhatsApp → bot gera código + link
#   wa.me. Amigo clica → manda mensagem "Indicado por XXXXX" → bot cria Lead.
#   Configurar número alvo (E.164 sem '+') via /api/v1/config:
#     POST {"key":"indicacao.whatsapp_alvo","value":"5547999998888"}
#   Sem config = usa EVOLUTION_INSTANCE como fallback.
#   Gestão em /indicacoes no dashboard (converter → aplicar crédito SGP).
#
# ── F7 — Bot por voz (OpenAI Whisper) ────────────────────────
#   Único requisito: OPENAI_API_KEY (já configurada acima para o LLM).
#   Monitorar custo:
#     ondeline_asr_audio_total          (sucessos)
#     ondeline_asr_failure_total{motivo}
#     ondeline_asr_skipped_total{motivo}
#   Custo aprox.: ~R$ 0,03 por áudio de 15s.
#   Aviso LGPD enviado automaticamente na 1a vez que cliente identificado
#   manda áudio (idempotente via clientes.asr_aviso_enviado_at).

# ── FCM (push notifications pro app Flutter do tecnico) ─────────
#   Service account JSON do Firebase Admin SDK.
#   Como obter: Firebase Console -> Project Settings -> Service Accounts
#   -> Generate new private key (baixa um JSON).
#
#   Recomendado (mais limpo): base64 do JSON inteiro:
#     base64 -i serviceAccount.json   # Mac
#     base64 -w 0 serviceAccount.json # Linux
#   Cola o resultado em uma linha aqui:
#FIREBASE_CREDENTIALS_B64=eyJ0eXBlIjoic2Vydmlj...
#
#   Alternativa (dev local): caminho absoluto pro arquivo no container.
#FIREBASE_CREDENTIALS_PATH=/etc/secrets/firebase.json
#
#   Vazio nos dois = push desligado (no-op). Util pra dev sem Firebase.
